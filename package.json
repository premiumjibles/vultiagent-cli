{
  "name": "vultiagent-cli",
  "version": "0.1.0",
  "description": "Agent-friendly Vultisig CLI with keyring auth",
  "type": "module",
  "bin": {
    "vasig": "./dist/index.js",
    "vasig-dev": "./bin/vasig-dev.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && biome check",
    "fix": "biome check --write --unsafe",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "vultisig",
    "crypto",
    "cli",
    "agent",
    "mpc"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vultisig/rujira": "^1.0.0",
    "@vultisig/sdk": "^0.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "keytar": "^7.9.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
